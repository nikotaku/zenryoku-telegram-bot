# Telegram Bot Token
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Notion API Key (Internal Integration Token)
# https://www.notion.so/my-integrations で作成
NOTION_API_KEY=your_notion_api_key_here

# Notion マスタDB ID (オプション、デフォルト値あり)
# NOTION_MASTER_DB_ID=20af9507-f0cf-811a-9397-000b1fd6918d

# Notion シフトDB ID (オプション、デフォルト値あり)
# シフトDBのデータベースID（Notion URLの末尾32文字）
# NOTION_SHIFT_DB_ID=256f9507-f0cf-8076-931f-ed70fc040520

# セラピストマップ (オプション、JSON形式で上書き可能)
# THERAPIST_MAP={"なお":"23ff9507-f0cf-80dd-bb02-db4fe5e8cc6d",...}

# Gemini API Key (SEO記事生成・ニュース生成・ブラウザエージェントLLM解析用)
GEMINI_API_KEY=your_gemini_api_key_here

# Imgur Client ID (画像アップロード用、オプション)
# https://api.imgur.com/oauth2/addclient で取得
# IMGUR_CLIENT_ID=your_imgur_client_id

# キャスカン ログイン情報
CASKAN_SHOP_ID=Zenryoku1209
CASKAN_LOGIN_ID=zr.sendai@gmail.com
CASKAN_PASSWORD=Zenryoku1209

# エスたま ログイン情報
ESTAMA_LOGIN_ID=zr.sendai@gmail.com
ESTAMA_PASSWORD=Zenryoku1209

# ブラウザエージェント設定
# PlaywrightはDocker内で自動インストールされます。
# Railway有料プラン推奨（Chromiumがメモリを使用するため）

# ─── bitbank 仮想通貨 API ────────────────────────────────────────────────
# bitbank のアクセスキーページで発行: https://app.bitbank.cc/account/apikey
# 権限: 参照（ポートフォリオ表示のみ）または 参照・取引・出金
BITBANK_API_KEY=your_bitbank_api_key_here
BITBANK_API_SECRET=your_bitbank_api_secret_here

# ─── Google Sheets 経費連携 ────────────────────────────────
# 経費を書き込むGoogleスプレッドシートのID
# スプレッドシートURLの /d/{ID}/ の部分
EXPENSE_SHEET_ID=1WpwYKqrameXK3yefsEyNYJUpyB_kkBNec-9MviEmncY

# Googleサービスアカウント認証（いずれか一方を設定）
#
# 方法1: サービスアカウントのJSONを文字列として直接設定（Railway等の環境変数に推奨）
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key_id":"...", ...}
#
# 方法2: サービスアカウントのJSONファイルのパスを設定
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
#
# サービスアカウントの作成手順:
# 1. Google Cloud Console でプロジェクトを作成
# 2. Google Sheets API を有効化
# 3. サービスアカウントを作成してJSONキーをダウンロード
# 4. スプレッドシートをサービスアカウントのメールアドレスに共有（編集者権限）
